import pytest

from runconf_ui.backend_interface import RunconfUIBackend

@pytest.fixture(scope='session')
def runconf_ui_backend(tmp_config_path):
    return RunconfUIBackend(
        apparatus='dummy',
        conf_directory=tmp_config_path.parent,
        use_local=True
    )    

def test_set_select(runconf_ui_backend, tmp_config_path, visibility_config_path):
    runconf_ui_backend.set_daq_version(tmp_config_path.parent)
    
    assert runconf_ui_backend.visbility_config_reader.path == visibility_config_path
    
    runconf_ui_backend.select_config(tmp_config_path.name)
    
    # TODO: Come up with some less bad tests...
    assert runconf_ui_backend.configuration is not None
    assert runconf_ui_backend.state_operations_tree is not None
    
    runconf_ui_backend.set_daq_version(None)
    assert runconf_ui_backend.configuration is None
    assert runconf_ui_backend.state_operations_tree is None